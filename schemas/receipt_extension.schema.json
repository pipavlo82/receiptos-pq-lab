{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReceiptOS Extension Envelope (PQ/Entropy/VRF)",
  "type": "object",
  "required": ["extension_version", "mode"],
  "properties": {
    "extension_version": {"const": "x1"},
    "mode": {
      "type": "string",
      "enum": ["baseline", "entropy_augmented", "hybrid"]
    },
    "entropy": {
      "type": "object",
      "properties": {
        "entropy_score": {"type": "number"},
        "entropy_source": {"type": "string"},
        "freshness_window_sec": {"type": "integer"}
      }
    },
    "vrf": {
      "type": "object",
      "properties": {
        "proof": {"type": "string"},
        "public_key": {"type": "string"},
        "domain": {"type": "string"}
      }
    },
    "pq_signature": {
      "type": "object",
      "properties": {
        "alg": {"type": "string"},
        "key_id": {"type": "string"},
        "sig": {"type": "string"}
      }
    },
    "policy_path": {
      "type": "object",
      "properties": {
        "selected_path": {"type": "string"},
        "fallback_path": {"type": "string"},
        "reason": {"type": "string"}
      }
    }
  }
}
